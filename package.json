{
  "name": "@jay-es/oxlint-eslint-configs",
  "version": "0.2.0",
  "description": "oxlint configs generated from ESLint's official recommended/all configs, filtered to rules oxlint supports.",
  "homepage": "https://github.com/jay-es/oxlint-eslint-configs#readme",
  "bugs": {
    "url": "https://github.com/jay-es/oxlint-eslint-configs/issues"
  },
  "license": "MIT",
  "author": "jay-es",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jay-es/oxlint-eslint-configs.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./*": "./dist/*.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "generate": "node scripts/generate.ts",
    "postbuild": "pnpm run generate",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint-plugin-promise": "^7.3.0",
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-n": "^18.2.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-perf": "^3.3.3",
    "eslint-plugin-unicorn": "^70.0.0",
    "oxlint": "^1.72.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite-plus": "^0.1.20"
  },
  "peerDependencies": {
    "oxlint": "*"
  },
  "peerDependenciesMeta": {
    "oxlint": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.9.0"
}
